# ---- X (Twitter) API v2 — OAuth 2.0 user context ----
# From your app at https://developer.x.com (OAuth 2.0 enabled).
X_CLIENT_ID=
# Only for a *confidential* (Web App / Automated) client. Leave blank for a
# public PKCE-only (Native) client.
X_CLIENT_SECRET=
# Must EXACTLY match the redirect URI registered on the X app.
X_REDIRECT_URI=http://127.0.0.1:8721/callback
X_SCOPES=tweet.read users.read offline.access
# Produced by running auth_setup.py once (bootstrap seed; the worker then
# persists the rotated token in SQLite).
X_REFRESH_TOKEN=

# Optional: read a curated List instead of the home timeline (cheaper, focused).
# X_LIST_ID=
X_MAX_RESULTS=100
X_MAX_PAGES=10

# ---- Anthropic (classification) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ---- Storage ----
# On Railway, mount a volume and point this inside it, e.g. /app/data/hiring.db
DB_PATH=./data/hiring.db

# ---- Email digest (any SMTP provider; stdlib smtplib) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_STARTTLS=true
EMAIL_FROM=
EMAIL_TO=sarthak.jain@warehousenow.in
EMAIL_ENABLED=true
